{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "tests/cli/**/*.ts", "tests/nia/**/*.ts", "tsup.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "worker",
    "src/mcp",
    "tests/worker",
    "tests/capture",
    "tests/mcp"
  ]
}
